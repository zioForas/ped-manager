# ── PED Manager · variabili d'ambiente (template) ──
# Copia questo file in `.env` e compila i valori. NON committare mai il .env reale.

# App / login
APP_USERNAME=admin
APP_PASSWORD=                      # password del pannello (scegline una)
APP_SECRET_KEY=                    # stringa random lunga (es. openssl rand -hex 32)
PUBLIC_BASE_URL=                   # URL pubblico in produzione (per i link nelle email)

# Cliente (default, sovrascritto da clienti/<slug>/strategia.json)
CLIENTE_EMAIL=

# AI providers (almeno uno; il sistema fa fallback automatico)
GROQ_API_KEY=
GEMINI_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=

# Email (Brevo HTTP API)
BREVO_API_KEY=
BREVO_SENDER=
BREVO_SENDER_NAME=
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Meta Graph API (Facebook + Instagram)
META_ACCESS_TOKEN=
META_PAGE_ACCESS_TOKEN=
META_PAGE_ID_FB=
META_INSTAGRAM_ACCOUNT_ID=
META_APP_ID=
META_APP_SECRET=

# Google Drive (service account per i media)
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_CREDENTIALS_PATH=clienti/example/.credentials/google_drive_service_account.json
GOOGLE_SERVICE_ACCOUNT_JSON=       # contenuto JSON del service account (in produzione)

# Opzionali / legacy (browser automation, non usati in produzione)
FB_EMAIL=
FB_PASSWORD=
FB_PAGE_NAME=
CANVA_EMAIL=
CANVA_PASSWORD=
NGROK_AUTH_TOKEN=
PUBLER_API_KEY=
